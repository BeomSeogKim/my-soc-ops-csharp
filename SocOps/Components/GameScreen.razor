@using SocOps.Models

<div class="game-screen">
    <header class="game-header">
        <button class="btn-abort" @onclick="OnReset">&#9664;&nbsp; Abort Mission</button>
        <span class="game-header-title">
            SOC OPS
            <span class="game-header-badge">&#9679; LIVE</span>
        </span>
        <span style="width:5rem"></span>
    </header>

    <p class="game-hint">Mark a tile when you find a matching operative</p>

    @if (HasBingo)
    {
        <div class="bingo-banner">&#10003;&nbsp; Line Confirmed &nbsp;//&nbsp; Bingo</div>
    }

    <div class="game-board-area">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
